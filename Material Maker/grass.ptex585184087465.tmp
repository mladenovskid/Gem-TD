0.0, 1.0) : normalize(slope);\n\tvec2 e = dx*norm_slope;\n\t\n\tvec4 rv = vec4(0.0);\n\tfloat sum = 0.0;\n\tfloat sigma = max($sigma*slope_strength, 0.0001);\n\tfor (float i = 0.0; i <= 50.0; i += 1.0) {\n\t\tfloat coef = exp(-0.5*(pow(i/sigma, 2.0)))/(6.28318530718*sigma*sigma);\n\t\trv += $in(uv+i*e)*coef;\n\t\tsum += coef;\n\t}\n\treturn rv/sum;\n}","name":"Slope Blur Fixed","outputs":[{"rgba":"$(name)_fct($uv)","type":"rgba"}],"parameters":[{"default":9,"first":4,"label":"Size","last":12,"name":"size","type":"size"},{"control":"None","default":0.5,"label":"Sigma","max":50,"min":0,"name":"sigma","step":0.1,"type":"float"}]}},{"name":"circle_splatter","type":"circle_splatter","parameters":{"count":16,"rings":2,"select_inputs":0,"scale_x":0.35,"scale_y":0.35,"radius":0.13,"spiral":0.46,"i_rotate":0,"i_scale":0,"rotate":21.9,"scale":0.15,"value":0.3},"node_position":{"x":691.764099,"y":265.288239},"seed_value":-21706},{"name":"buffer_2","type":"buffer","parameters":{"size":11,"lod":0},"node_position":{"x":986.024536,"y":226.384491}},{"name":"comment","type":"comment","parameters":{},"node_position":{"x":847.04126,"y":20.399185},"title":"Comment","color":{"type":"Color","r":1,"g":0.5,"b":0,"a":1},"text":"Patch of grass, becouse tiler random rotate is totally \"random\"","size":{"x":217,"y":97}},{"name":"transform2_3","type":"transform2","parameters":{"translate_x":0,"translate_y":0,"rotate":0,"scale_x":0.185,"scale_y":1,"mode":0},"node_position":{"x":-770.202515,"y":-324.216919}},{"name":"blend_3","type":"blend","parameters":{"blend_type":11,"amount":0.06},"node_position":{"x":-41.976681,"y":-146.849731}},{"name":"shape_2","type":"shape","parameters":{"shape":0,"sides":2,"radius":0.906667,"edge":0.2},"node_position":{"x":-1575.282349,"y":-336.191071}},{"name":"transform2_4","type":"transform2","parameters":{"translate_x":0,"translate_y":0,"rotate":0,"scale_x":0.255,"scale_y":1,"mode":0},"node_position":{"x":-1295.680054,"y":-208.505966}},{"name":"gradient_2","type":"